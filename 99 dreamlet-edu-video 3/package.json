{
  "name": "kilocode-memory-bank",
  "version": "1.0.0",
  "description": "KiloCode Memory Bank System - Automated workflows and scripts for project context management",
  "main": "scripts/index.js",
  "scripts": {
    "init": "node scripts/init-memory-bank.js",
    "validate": "node scripts/validate-memory-bank.js",
    "update": "node scripts/update-memory-bank.js",
    "status": "node scripts/status-report.js",
    "setup": "node scripts/setup-dev-env.js",
    "check:templates": "node scripts/check-templates.js",
    "check:consistency": "node scripts/check-consistency.js",
    "reminder": "node scripts/update-reminder.js",
    "onboard": "node scripts/onboard-member.js",
    "handoff": "node scripts/project-handoff.js",
    "review": "node scripts/monthly-review.js",
    "help": "node scripts/help.js",
    "test": "npm run validate && npm run check:templates && npm run check:consistency"
  },
  "keywords": [
    "kilocode",
    "memory-bank",
    "project-management",
    "documentation",
    "automation",
    "workflow"
  ],
  "author": "KiloCode Team",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^9.4.1",
    "inquirer": "^8.2.5",
    "fs-extra": "^11.1.0",
    "glob": "^8.1.0",
    "markdown-table": "^3.0.3"
  },
  "devDependencies": {
    "jest": "^29.3.1",
    "eslint": "^8.28.0"
  },
  "bin": {
    "kilocode-mb": "./scripts/cli.js"
  },
  "files": [
    "scripts/",
    ".kilocode/",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kilocode/memory-bank.git"
  },
  "bugs": {
    "url": "https://github.com/kilocode/memory-bank/issues"
  },
  "homepage": "https://github.com/kilocode/memory-bank#readme"
}